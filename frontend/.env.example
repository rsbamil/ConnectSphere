# ConnectSphere Frontend — Environment Variables
# Copy this file to .env and fill in your Render service URLs

# Leave empty during local dev — Vite proxy handles routing
# In production, set these to your Render service URLs:

VITE_AUTH_URL=https://cs-auth-service.onrender.com
VITE_POST_URL=https://cs-post-service.onrender.com
VITE_LIKE_URL=https://cs-like-service.onrender.com
VITE_COMMENT_URL=https://cs-comment-service.onrender.com
VITE_FOLLOW_URL=https://cs-follow-service.onrender.com
VITE_NOTIF_URL=https://cs-notif-service.onrender.com
VITE_FEED_URL=https://cs-feed-service.onrender.com

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
